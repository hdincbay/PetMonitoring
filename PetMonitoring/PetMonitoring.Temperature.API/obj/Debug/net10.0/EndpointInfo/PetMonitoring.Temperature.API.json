{
  "openapi": "3.1.1",
  "info": {
    "title": "PetMonitoring.Temperature.API | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://127.0.0.1:7026"
    },
    {
      "url": "http://127.0.0.1:5042"
    }
  ],
  "paths": {
    "/api/Temperature/Add": {
      "post": {
        "tags": [
          "Temperature"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddTemperatureCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddTemperatureCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddTemperatureCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Temperature/GetByDevice": {
      "get": {
        "tags": [
          "Temperature"
        ],
        "parameters": [
          {
            "name": "DeviceSerialNumber",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddTemperatureCommand": {
        "required": [
          "deviceSerialNumber",
          "celsiusValue"
        ],
        "type": "object",
        "properties": {
          "deviceSerialNumber": {
            "type": "string"
          },
          "celsiusValue": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Temperature"
    }
  ]
}