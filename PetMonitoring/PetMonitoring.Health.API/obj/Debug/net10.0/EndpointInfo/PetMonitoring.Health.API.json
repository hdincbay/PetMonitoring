{
  "openapi": "3.1.1",
  "info": {
    "title": "PetMonitoring.Health.API | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://127.0.0.1:7140"
    },
    {
      "url": "http://127.0.0.1:5113"
    }
  ],
  "paths": {
    "/api/HeartRate/Add": {
      "post": {
        "tags": [
          "HeartRate"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddHeartRateCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddHeartRateCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddHeartRateCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/HeartRate/GetByDevice": {
      "get": {
        "tags": [
          "HeartRate"
        ],
        "parameters": [
          {
            "name": "DeviceId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddHeartRateCommand": {
        "required": [
          "deviceId",
          "bpm"
        ],
        "type": "object",
        "properties": {
          "deviceId": {
            "type": "string",
            "format": "uuid"
          },
          "bpm": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "HeartRate"
    }
  ]
}